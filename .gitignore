__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.env
.env.*
.pytest_cache/
.ruff_cache/
.mypy_cache/
.DS_Store
*.log
.aiforge/audit/*.jsonl
!.aiforge/audit/.gitkeep
# .claude/ 整体入库(M2/M3 交付物:agents/skills/settings.json);只忽略本机个人配置
.claude/settings.local.json

# 调研/实验文件夹：不属于核心仓库，且会污染健康度探针基线（死代码/重复/复杂度噪声）
AI工程化开发企业软件系统方案-调研/
# /project-health 探针默认输出（若指定 --out 落到仓库内）
.project-health/
# 本机工具状态(cursor 本地 plan 等),非仓库资产
.cursor/
# 无 feature 归属的本地草稿 receipt(gate-judge/gate-commit 不带 --feature 时落这里)
specs/_workspace/
# gate-commit receipt 是"记录本次提交"的产物,无法进它自己那个 commit;本地反馈层产物,
# 权威 = CI 重跑(契约 01)。gate-spec/gate-trace receipt 仍入库(冻结链需要)。
specs/*/gates/gate-commit.json
# project-dashboard 生成的 HTML 产物(make dashboard-project 随时重生成;GitHub 不渲染 HTML)
docs/project-dashboard.html
# bpmn-status 生成物(重跑 aiforge bpmn-status 即最新;备援源 sdlc-pipeline.js 入库)
docs/flows/sdlc-status.js
