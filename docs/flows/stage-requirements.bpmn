        <di:waypoint x="1996" y="455"/><di:waypoint x="2020" y="452"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
