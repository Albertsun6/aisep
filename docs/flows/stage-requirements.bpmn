      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="e2_t8b" bpmnElement="t8b">
        <di:waypoint x="1700" y="370"/><di:waypoint x="1750" y="370"/>
      </bpmndi:BPMNEdge>
